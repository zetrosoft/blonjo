# ============================================
# BLONJO & SAJEN - Environment Variables Template
# ============================================
# Copy file ini menjadi .env dan isi sesuai environment Anda.
# cp .env.example .env

# --- AI / Ollama ---
OLLAMA_HOST=http://host.docker.internal:11434

# --- Database ---
POSTGRES_USER=sajen_user
POSTGRES_PASSWORD=secret
POSTGRES_DB=blonjo_db
DATABASE_URL=postgresql://sajen_user:secret@sajen-db:5432/blonjo_db

# --- Redis ---
REDIS_URL=redis://sajen-redis:6379/0
CELERY_BROKER_URL=redis://sajen-redis:6379/0

# --- Frontend ---
VITE_API_URL=http://localhost:8005/api/v1
